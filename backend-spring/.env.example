# Environment Variables Example
# Copy this to .env and fill in your actual values
# NOTE: This file should NOT be committed to version control

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=8080

# ============================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================
# Default points to Railway.app database
# Update for your own database
DB_URL=jdbc:mysql://yamanote.proxy.rlwy.net:57916/railway
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# ============================================
# JWT CONFIGURATION (REQUIRED FOR PRODUCTION)
# ============================================
# Use a strong secret key (at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-at-least-32-chars

# ============================================
# EMAIL CONFIGURATION (REQUIRED FOR OTP)
# ============================================
# Using Gmail SMTP - requires Gmail App Password
# Get App Password from: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=smartfinanceanalyzer@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here
MAIL_FROM=smartfinanceanalyzer@gmail.com

# ============================================
# CORS CONFIGURATION (OPTIONAL)
# ============================================
# For production, update with your domain
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
